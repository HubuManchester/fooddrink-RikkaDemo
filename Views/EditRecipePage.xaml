<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeHub.Views.EditRecipePage"
              Title="Edit Recipe">
    <Grid RowDefinitions="Auto,*">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="16">
                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                         <Label Text="Recipe Image" FontAttributes="Bold" FontSize="16"/>
                        <Grid HeightRequest="200">
                            <Image Source="{Binding ImagePath}" Aspect="AspectFill"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" VerticalOptions="End" Margin="0,10">
                                 <Button Grid.Row="0" Text="Take Photo"
                                         VerticalOptions="End"
                                         HorizontalOptions="Center"
                                         Margin="0,10"
                                         BackgroundColor="#512BD4"
                                         TextColor="White"
                                         CornerRadius="20"
                                         Clicked="OnTakePhotoClicked"/>
                                 <Button Grid.Row="1" Text="Reset Image"
                                         VerticalOptions="End"
                                         HorizontalOptions="Center"
                                         Margin="0,10"
                                         BackgroundColor="#4CAF50"
                                         TextColor="White"
                                         CornerRadius="20"
                                         Clicked="OnResetImageClicked"/>
                                <Entry Grid.Row="2"
                                       Text="{Binding ImagePath}"
                                        Placeholder="Enter image path (e.g., food_1.png)"
                                       Margin="0,10"
                                       FontSize="12"/>
                            </Grid>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                         <Label Text="Recipe Name *" FontAttributes="Bold" FontSize="16"/>
                         <Entry Text="{Binding Title}" Placeholder="Enter recipe name"/>
                        
                         <Label Text="Description" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
                         <Editor Text="{Binding Description}"
                                 Placeholder="Describe this recipe..."
                                 HeightRequest="80"
                                 AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                         <Label Text="Category" FontAttributes="Bold" FontSize="16"/>
                         <Picker Title="Select category" ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}"/>
                        
                         <Label Text="Difficulty" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
                         <Picker Title="Select difficulty" ItemsSource="{Binding Difficulties}" SelectedItem="{Binding Difficulty}"/>
                        
                        <Grid Margin="0,10,0,0" ColumnDefinitions="*,*">
                             <VerticalStackLayout Grid.Column="0" Spacing="5">
                                 <Label Text="Prep Time (min)" FontAttributes="Bold" FontSize="14"/>
                                 <Entry Text="{Binding PrepTime}" Keyboard="Numeric" Placeholder="10"/>
                             </VerticalStackLayout>
                             <VerticalStackLayout Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                                 <Label Text="Cook Time (min)" FontAttributes="Bold" FontSize="14"/>
                                 <Entry Text="{Binding CookTime}" Keyboard="Numeric" Placeholder="10"/>
                             </VerticalStackLayout>
                        </Grid>
                        
                        <Grid Margin="0,10,0,0" ColumnDefinitions="*,*">
                             <VerticalStackLayout Grid.Column="0" Spacing="5">
                                 <Label Text="Servings" FontAttributes="Bold" FontSize="14"/>
                                 <Entry Text="{Binding Servings}" Keyboard="Numeric" Placeholder="1"/>
                             </VerticalStackLayout>
                             <VerticalStackLayout Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                                 <Label Text="Calories (kcal)" FontAttributes="Bold" FontSize="14"/>
                                 <Entry Text="{Binding Calories}" Keyboard="Numeric" Placeholder="200"/>
                             </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                         <Label Text="Ingredients *" FontAttributes="Bold" FontSize="16"/>
                         <Label Text="Enter one ingredient per line" FontSize="12" TextColor="Gray"/>
                         <Editor Text="{Binding Ingredients}"
                                 Placeholder="E.g.&#10;Eggs 4&#10;Tomatoes 2&#10;Salt to taste"
                                 HeightRequest="120"
                                 AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                         <Label Text="Instructions *" FontAttributes="Bold" FontSize="16"/>
                         <Label Text="Enter one step per line" FontSize="12" TextColor="Gray"/>
                         <Editor Text="{Binding Instructions}"
                                 Placeholder="E.g.&#10;Wash and chop tomatoes&#10;Beat eggs&#10;Heat oil, add eggs and cook"
                                 HeightRequest="120"
                                 AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                 <Button Text="Save Changes"
                         Margin="0,0,0,20"
                         BackgroundColor="#FF9800"
                         TextColor="White"
                         CornerRadius="25"
                         Clicked="OnSaveClicked"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="0" Padding="10">
            <ImageButton Source="back" 
                         HeightRequest="40" 
                         WidthRequest="40" 
                         Clicked="OnBackClicked"/>
        </Grid>
    </Grid>
</ContentPage>