<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeHub.Views.EditRecipePage"
             Title="编辑食谱">
    <Grid RowDefinitions="Auto,*">
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="16">
                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="食谱图片" FontAttributes="Bold" FontSize="16"/>
                        <Grid HeightRequest="200">
                            <Image Source="{Binding ImagePath}" Aspect="AspectFill"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" VerticalOptions="End" Margin="0,10">
                                <Button Grid.Row="0" Text="📷 拍照" 
                                        VerticalOptions="End" 
                                        HorizontalOptions="Center" 
                                        Margin="0,10"
                                        BackgroundColor="#512BD4"
                                        TextColor="White"
                                        CornerRadius="20"
                                        Clicked="OnTakePhotoClicked"/>
                                <Button Grid.Row="1" Text="🔄 重置图片" 
                                        VerticalOptions="End" 
                                        HorizontalOptions="Center" 
                                        Margin="0,10"
                                        BackgroundColor="#4CAF50"
                                        TextColor="White"
                                        CornerRadius="20"
                                        Clicked="OnResetImageClicked"/>
                                <Entry Grid.Row="2"
                                       Text="{Binding ImagePath}"
                                       Placeholder="输入图片路径 (如: food_1.png)"
                                       Margin="0,10"
                                       FontSize="12"/>
                            </Grid>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="食谱名称 *" FontAttributes="Bold" FontSize="16"/>
                        <Entry Text="{Binding Title}" Placeholder="输入食谱名称"/>
                        
                        <Label Text="描述" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
                        <Editor Text="{Binding Description}" 
                                Placeholder="描述这个食谱..." 
                                HeightRequest="80" 
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="分类" FontAttributes="Bold" FontSize="16"/>
                        <Picker Title="选择分类" ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}"/>
                        
                        <Label Text="难度" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
                        <Picker Title="选择难度" ItemsSource="{Binding Difficulties}" SelectedItem="{Binding Difficulty}"/>
                        
                        <Grid Margin="0,10,0,0" ColumnDefinitions="*,*">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="准备时间（分钟）" FontAttributes="Bold" FontSize="14"/>
                                <Entry Text="{Binding PrepTime}" Keyboard="Numeric" Placeholder="10"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                                <Label Text="烹饪时间（分钟）" FontAttributes="Bold" FontSize="14"/>
                                <Entry Text="{Binding CookTime}" Keyboard="Numeric" Placeholder="10"/>
                            </VerticalStackLayout>
                        </Grid>
                        
                        <Grid Margin="0,10,0,0" ColumnDefinitions="*,*">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="份量（人）" FontAttributes="Bold" FontSize="14"/>
                                <Entry Text="{Binding Servings}" Keyboard="Numeric" Placeholder="1"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                                <Label Text="热量（卡路里）" FontAttributes="Bold" FontSize="14"/>
                                <Entry Text="{Binding Calories}" Keyboard="Numeric" Placeholder="200"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="食材 *" FontAttributes="Bold" FontSize="16"/>
                        <Label Text="每行输入一种食材" FontSize="12" TextColor="Gray"/>
                        <Editor Text="{Binding Ingredients}" 
                                Placeholder="例如：&#10;鸡蛋 4个&#10;番茄 2个&#10;盐 适量" 
                                HeightRequest="120" 
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="10" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="制作步骤 *" FontAttributes="Bold" FontSize="16"/>
                        <Label Text="每行输入一个步骤" FontSize="12" TextColor="Gray"/>
                        <Editor Text="{Binding Instructions}" 
                                Placeholder="例如：&#10;将番茄洗净切块&#10;鸡蛋打散备用&#10;热锅倒油，倒入蛋液炒成块" 
                                HeightRequest="120" 
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                <Button Text="💾 保存修改" 
                        Margin="0,0,0,20"
                        BackgroundColor="#FF9800" 
                        TextColor="White" 
                        CornerRadius="25"
                        Clicked="OnSaveClicked"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="0" Padding="10">
            <ImageButton Source="back" 
                         HeightRequest="40" 
                         WidthRequest="40" 
                         Clicked="OnBackClicked"/>
        </Grid>
    </Grid>
</ContentPage>