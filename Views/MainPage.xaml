<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeHub.Views.MainPage"
             Title="RecipeHub">

     <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        <Grid Grid.Row="0" Padding="16,20,16,10" BackgroundColor="#512BD4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0"
                   Text="食谱中心"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"/>

            <Frame Grid.Column="1"
                   Padding="8"
                   BackgroundColor="White"
                   CornerRadius="20"
                   HasShadow="False">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDarkModeTapped"/>
                </Frame.GestureRecognizers>
                <Label Text="{Binding IsDarkMode, Converter={StaticResource BoolToThemeConverter}}"
                       FontSize="20"/>
            </Frame>
        </Grid>

        <SearchBar Grid.Row="1"
                   Placeholder="搜索食谱..."
                   Text="{Binding SearchText}"
                   Margin="16,10"
                   BackgroundColor="LightGray"
                   PlaceholderColor="Gray"/>

         <CollectionView Grid.Row="2"
                         ItemsSource="{Binding Categories}"
                         Margin="16,5"
                         HeightRequest="50">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12,6"
                           CornerRadius="20"
                           BackgroundColor="{Binding SelectedCategory, Source={RelativeSource AncestorType={x:Type ContentPage}}, Converter={StaticResource CategoryToColorConverter}}"
                           HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding}"
                                                   Tapped="OnCategoryTapped"/>
                        </Frame.GestureRecognizers>
                        <Label Text="{Binding Icon}"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="3">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>

            <CollectionView ItemsSource="{Binding Recipes}"
                            IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                            Margin="16">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="0"
                               CornerRadius="12"
                               HasShadow="True"
                               BackgroundColor="White">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="{Binding}"
                                                       Tapped="OnRecipeTapped"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="Auto,*,Auto,Auto">
                                <Image Grid.Row="0"
                                       Source="{Binding ImagePath}"
                                       HeightRequest="120"
                                       Aspect="AspectFill"/>

                                <Label Grid.Row="1"
                                       Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"
                                       Margin="12,8,12,4"/>

                                <Grid Grid.Row="2" Margin="12,0,12,4" ColumnDefinitions="Auto,Auto,Auto,Auto">
                                    <Label Grid.Column="0"
                                           Text="⏱️"
                                           FontSize="14"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding PrepTime, StringFormat='{0}分钟'}"
                                           FontSize="12"
                                           TextColor="Gray"
                                           Margin="4,0"/>

                                    <Label Grid.Column="2"
                                           Text="🔥"
                                           FontSize="14"
                                           Margin="8,0,0,0"/>
                                    <Label Grid.Column="3"
                                           Text="{Binding Calories, StringFormat='{0}卡'}"
                                           FontSize="12"
                                           TextColor="Gray"
                                           Margin="4,0"/>
                                </Grid>

                                <Grid Grid.Row="3" Margin="12,0,12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0"
                                           Text="{Binding Difficulty}"
                                           FontSize="12"
                                           TextColor="Gray"
                                           VerticalOptions="Center"/>

                                    <ImageButton Grid.Column="1"
                                                 Source="favorite_empty"
                                                 HeightRequest="28"
                                                 WidthRequest="28"
                                                 HorizontalOptions="End">
                                        <ImageButton.Triggers>
                                            <DataTrigger TargetType="ImageButton"
                                                         Binding="{Binding IsFavorite}"
                                                         Value="True">
                                                <Setter Property="Source" Value="favorite_filled"/>
                                            </DataTrigger>
                                        </ImageButton.Triggers>
                                        <ImageButton.GestureRecognizers>
                                            <TapGestureRecognizer CommandParameter="{Binding}"
                                                                   Tapped="OnFavoriteTapped"/>
                                        </ImageButton.GestureRecognizers>
                                    </ImageButton>
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <Label Text="没有找到食谱"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="18"
                           TextColor="Gray"/>
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <Grid Grid.Row="4" Margin="16,16,16,0" ColumnDefinitions="*,*">
            <Button Grid.Column="0"
                    Text="➕ 添加食谱"
                    VerticalOptions="End"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="25"
                    Clicked="OnAddRecipeClicked"/>
            <Button Grid.Column="1"
                    Text="📱 摇一摇随机推荐"
                    VerticalOptions="End"
                    Margin="8,0,0,0"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="25"
                    Clicked="OnShakeClicked"/>
        </Grid>
    </Grid>
</ContentPage>